{% extends 'base.html.twig' %}

{% block body %}
<div class="page-header">
    <div>
        <h1>{{ trida.nazev }}</h1>
        <p class="muted">Správa žáků, věcí a zapůjčení</p>
    </div>
    <div class="header-actions">
        <a href="{{ path('app_zak_create', {tridaId: trida.id}) }}" class="btn btn-small">+ Žák</a>
        <a href="{{ path('app_vec_create', {tridaId: trida.id}) }}" class="btn btn-small">+ Věc</a>
        <a href="{{ path('app_zapujceni_create', {tridaId: trida.id}) }}" class="btn btn-small btn-primary">Zapůjčit</a>
        {% if is_granted('ROLE_UCITEL') %}
        <button type="button" class="btn btn-small btn-danger" id="trida-delete-open">Smazat třídu</button>
        {% endif %}
    </div>
</div>

<section class="section">
    <h2>Žáci</h2>
    {% if zaci is empty %}
    <p class="muted">Zatím žádní žáci. <a href="{{ path('app_zak_create', {tridaId: trida.id}) }}">Přidej prvního</a></p>
    {% else %}
    <table class="table">
        <thead><tr><th>Jméno</th><th>Příjmení</th><th class="actions-col"></th></tr></thead>
        <tbody>
        {% for z in zaci %}
        <tr>
            <td>{{ z.jmeno }}</td>
            <td>{{ z.prijmeni }}</td>
            <td class="actions">
                <a href="{{ path('app_zak_edit', {id: z.id}) }}" class="btn btn-small btn-outline-primary">Upravit</a>
                <a href="{{ path('app_zak_delete', {id: z.id}) }}"
                   class="btn btn-small btn-outline-danger"
                   onclick="return confirm('Smazat žáka?')">Smazat</a>
            </td>
        </tr>
        {% endfor %}
        </tbody>
    </table>
    {% endif %}
</section>

<section class="section">
    <h2>Věci</h2>
    {% if veci is empty %}
    <p class="muted">Zatím žádné věci. <a href="{{ path('app_vec_create', {tridaId: trida.id}) }}">Přidej první</a></p>
    {% else %}
    <div class="vec-grid">
        {% for v in veci %}
        <div class="vec-card {{ v.zapujcena ? 'vec-borrowed' : '' }}"
             {% if v.zapujcena %}title="{{ v.tooltipZapujceni }}"{% endif %}>
            {% if v.foto %}
            <img src="{{ v.foto }}" alt="{{ v.nazev }}" class="vec-photo">
            {% else %}
            <div class="vec-photo vec-photo-placeholder">📦</div>
            {% endif %}
            <div class="vec-info">
                <strong>{{ v.nazev }}</strong>
                <span class="badge {{ v.zapujcena ? 'badge-warn' : 'badge-ok' }}">
                    {{ v.zapujcena ? 'Půjčeno' : 'Volné' }}
                </span>
            </div>
            <div class="vec-actions">
                <a href="{{ path('app_vec_edit', {id: v.id}) }}" class="btn btn-small btn-outline-primary">Upravit</a>
                {% if not v.zapujcena %}
                <a href="{{ path('app_vec_delete', {id: v.id}) }}"
                   class="btn btn-small btn-outline-danger"
                   onclick="return confirm('Smazat věc?')">Smazat</a>
                {% endif %}
            </div>
        </div>
        {% endfor %}
    </div>
    {% endif %}
</section>

<section class="section">
    <h2>Zapůjčení</h2>
    {% if aktivniZapujceni is empty %}
    <p class="muted">Žádné aktivní zapůjčení.
        <a href="{{ path('app_zapujceni_create', {tridaId: trida.id}) }}">Zapůjčit věc</a>
    </p>
    {% else %}
    <table class="table">
        <thead>
        <tr>
            <th>Věc</th>
            <th>Žák</th>
            <th>Zapůjčeno</th>
            <th>Poznámka</th>
            <th class="actions-col"></th>
        </tr>
        </thead>
        <tbody>
        {% for zp in aktivniZapujceni %}
        <tr class="row-active">
            <td>{{ zp.vecNazev }}</td>
            <td>{{ zp.zakCeleJmeno }}</td>
            <td>{{ zp.datumZapujceni|date('d.m.Y H:i') }}</td>
            <td>{{ zp.poznamka ?: '—' }}</td>
            <td class="actions">
                <a href="{{ path('app_zapujceni_return', {id: zp.id}) }}"
                   class="btn btn-small btn-outline-success"
                   onclick="return confirm('Označit jako vrácené?')">Vrátit</a>
            </td>
        </tr>
        {% endfor %}
        </tbody>
    </table>
    {% endif %}
</section>

<section class="section">
    <h2>Historie zapůjčení</h2>
    {% if historieZapujceni is empty %}
    <p class="muted">Zatím žádná vrácená zapůjčení.</p>
    {% else %}
    <table class="table">
        <thead>
        <tr>
            <th>Věc</th>
            <th>Žák</th>
            <th>Zapůjčeno</th>
            <th>Vráceno</th>
            <th>Poznámka</th>
        </tr>
        </thead>
        <tbody>
        {% for zp in historieZapujceni %}
        <tr>
            <td>{{ zp.vecNazev }}</td>
            <td>{{ zp.zakCeleJmeno }}</td>
            <td>{{ zp.datumZapujceni|date('d.m.Y H:i') }}</td>
            <td>{{ zp.datumVraceni ? zp.datumVraceni|date('d.m.Y H:i') : '—' }}</td>
            <td>{{ zp.poznamka ?: '—' }}</td>
        </tr>
        {% endfor %}
        </tbody>
    </table>
    {% endif %}
</section>

<p><a href="{{ path('app_dashboard') }}">← Zpět na přehled</a></p>

{% if is_granted('ROLE_UCITEL') %}
<div class="modal" id="trida-delete-modal" hidden>
    <div class="modal-backdrop" data-modal-close></div>
    <div class="modal-dialog" role="dialog" aria-labelledby="trida-delete-title" aria-modal="true">
        <h2 id="trida-delete-title">Smazat třídu?</h2>
        <p class="muted">Tato akce je nevratná. Smaže se celá třída včetně žáků, věcí a historie zapůjčení.</p>
        <p>Pro potvrzení napiš přesně název třídy: <strong>{{ trida.nazev }}</strong></p>
        <form method="post" action="{{ path('app_trida_delete', {id: trida.id}) }}" id="trida-delete-form" class="form">
            <label>Název třídy
                <input type="text" name="potvrzeni" id="trida-delete-input" autocomplete="off" spellcheck="false" required>
            </label>
            <div class="form-actions">
                <button type="submit" class="btn btn-danger" id="trida-delete-submit" disabled>Trvale smazat třídu</button>
                <button type="button" class="btn btn-outline" data-modal-close>Zrušit</button>
            </div>
        </form>
    </div>
</div>

<script>
(function () {
    const expected = {{ trida.nazev|json_encode|raw }};
    const modal = document.getElementById('trida-delete-modal');
    const openBtn = document.getElementById('trida-delete-open');
    const input = document.getElementById('trida-delete-input');
    const submit = document.getElementById('trida-delete-submit');
    const form = document.getElementById('trida-delete-form');

    if (!modal || !openBtn || !input || !submit || !form) {
        return;
    }

    function matches() {
        return input.value.trim() === expected;
    }

    function updateSubmit() {
        submit.disabled = !matches();
    }

    function openModal() {
        modal.hidden = false;
        document.body.classList.add('modal-open');
        input.value = '';
        updateSubmit();
        input.focus();
    }

    function closeModal() {
        modal.hidden = true;
        document.body.classList.remove('modal-open');
        input.value = '';
        updateSubmit();
    }

    openBtn.addEventListener('click', openModal);
    input.addEventListener('input', updateSubmit);

    modal.querySelectorAll('[data-modal-close]').forEach(function (el) {
        el.addEventListener('click', closeModal);
    });

    document.addEventListener('keydown', function (e) {
        if (!modal.hidden && e.key === 'Escape') {
            closeModal();
        }
    });

    form.addEventListener('submit', function (e) {
        if (!matches()) {
            e.preventDefault();
            updateSubmit();
        }
    });
})();
</script>
{% endif %}
{% endblock %}
