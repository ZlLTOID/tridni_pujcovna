{% extends 'base.html.twig' %}

{% block body %}
<h1>Změna hesla</h1>
<p>Učitel: <strong>{{ ucitel.celeJmeno }}</strong>
   (<code>{{ ucitel.username }}</code>)</p>

<form method="post" action="{{ path('app_admin_password_store', {id: ucitel.id}) }}" class="form form-narrow">
    <label>Nové heslo
        <input type="password" name="password" required minlength="4" autofocus>
    </label>
    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Uložit heslo</button>
        <a href="{{ path('app_admin') }}" class="btn btn-outline">Zpět</a>
    </div>
</form>
{% endblock %}
